# Supabase (già in uso)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Obbligatorio per login studenti con LOGOS
SUPABASE_SERVICE_ROLE_KEY=
LOGOS_API_URL=https://your-logos-api.example.com

# Opzionale: se LOGOS ha un endpoint di login che restituisce un token
# (altrimenti si usa Basic Auth con email:password su GET /api/Students)
LOGOS_AUTH_URL=https://your-logos-api.example.com/api/Auth/Login
