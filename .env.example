# Copia questo file in .env.local e inserisci i valori reali.
# Next.js carica .env.local (non .env.example). Dopo aver modificato le variabili, riavvia il server.

# Supabase (già in uso)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Obbligatorio per login studenti con LOGOS (LogosUni Laba API)
# Produzione: api-prod. Swagger: https://logosuni.laba.biz/api-prod/swagger/v1/swagger.json
SUPABASE_SERVICE_ROLE_KEY=
LOGOS_API_URL=https://logosuni.laba.biz/api-prod

# Token OAuth2 (IdentityServer). Con questo le API usano Bearer invece di Basic Auth.
LOGOS_AUTH_URL=https://logosuni.laba.biz/identityserver/connect/token

# Richiesti da LogosUni: senza client_id si ottiene "invalid_client". Chiedere a LABA i valori.
LOGOS_CLIENT_ID=
LOGOS_CLIENT_SECRET=
